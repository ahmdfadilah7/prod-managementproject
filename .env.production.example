# =============================================================================
# ManagementPro — Production (.env di server)
# Salin: cp .env.production.example .env lalu sesuaikan nilai di bawah.
# =============================================================================

APP_NAME=ManagementPro
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://manpro.astrindotour.co.id

# UTC di server; tampilan user mengikuti cabang / APP_DISPLAY_TIMEZONE
APP_TIMEZONE=UTC
APP_DISPLAY_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Database production (HRIS / helpdesk)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_ask_hris
DB_USERNAME=
DB_PASSWORD=

# Mode HRIS — kategori helpdesk, tiket, project
HRIS_MODE=true
HRIS_DEFAULT_COMPANY_ID=1
# false = semua user aktif akses semua menu (permission map HRIS dinonaktifkan)
HRIS_PERMISSION_MAP_ENABLED=false

# Lampiran pesan tiket dari storage website HRIS
HRIS_STORAGE_URL=https://haime.astrindotour.co.id
HRIS_STORAGE_PATH=helpdesk-ticket-messages
# WAJIB — path absolut storage/app/public aplikasi HRIS (upload lampiran tiket)
HRIS_STORAGE_ROOT=/home/programmer/WebApps/ask_hris/storage/app/public
HRIS_STORAGE_URL_PREFIX=storage
HRIS_STORAGE_ALLOW_LOCAL_FALLBACK=false

# URL SPA (sama dengan APP_URL jika satu domain; untuk CORS & link reset password)
FRONTEND_URL=https://manpro.astrindotour.co.id

# Sanctum / CORS — domain frontend tanpa protokol ganda di CORS (pakai FRONTEND_URL)
# Tambahan domain dipisah koma jika perlu:
# CORS_ALLOWED_ORIGINS=https://managementpro.example.com
SANCTUM_STATEFUL_DOMAINS=manpro.astrindotour.co.id

# Di belakang Nginx/HTTPS reverse proxy
TRUST_PROXIES=*

# Auth token
AUTH_REMEMBER_TOKEN_DAYS=30
AUTH_SESSION_TOKEN_HOURS=8

# Reset password — aktifkan setelah SMTP siap
PASSWORD_RESET_SEND_MAIL=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Mail production (contoh)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
